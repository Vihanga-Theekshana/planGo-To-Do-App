<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/custom_bottom_nav"
    android:layout_width="match_parent"
    android:layout_height="78dp"
    android:background="@drawable/bg_bottom_nav_bar"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="22dp"
    android:paddingTop="6dp"
    android:paddingEnd="22dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:id="@+id/nav_item_tasks"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:background="@drawable/bg_bottom_nav_item"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="76dp"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="7dp"
        android:paddingEnd="12dp"
        android:paddingBottom="5dp">

        <ImageView
            android:id="@+id/nav_icon_tasks"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:duplicateParentState="true"
            android:src="@drawable/ic_tasks_nav"
            app:tint="@color/bottom_nav_item_icon_color" />

        <TextView
            android:id="@+id/nav_label_tasks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:duplicateParentState="true"
            android:text="@string/nav_tasks"
            android:textColor="@color/bottom_nav_item_label_color"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_item_profile"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:background="@drawable/bg_bottom_nav_item"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="76dp"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="7dp"
        android:paddingEnd="12dp"
        android:paddingBottom="5dp">

        <ImageView
            android:id="@+id/nav_icon_profile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:duplicateParentState="true"
            android:src="@drawable/ic_nav_profile"
            app:tint="@color/bottom_nav_item_icon_color" />

        <TextView
            android:id="@+id/nav_label_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:duplicateParentState="true"
            android:text="@string/nav_profile"
            android:textColor="@color/bottom_nav_item_label_color"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_item_dev_info"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:background="@drawable/bg_bottom_nav_item"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="76dp"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="7dp"
        android:paddingEnd="12dp"
        android:paddingBottom="5dp">

        <ImageView
            android:id="@+id/nav_icon_dev_info"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:duplicateParentState="true"
            android:src="@drawable/ic_info_exclamation"
            app:tint="@color/bottom_nav_item_icon_color" />

        <TextView
            android:id="@+id/nav_label_dev_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:duplicateParentState="true"
            android:text="@string/nav_dev_info"
            android:textColor="@color/bottom_nav_item_label_color"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
