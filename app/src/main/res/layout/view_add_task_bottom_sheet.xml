<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="28dp"
    android:paddingEnd="24dp"
    android:paddingBottom="32dp">

    <!-- Component Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_new_task"
        android:textColor="#1F2937"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Task Title Input with correct background and inputType -->
    <EditText
        android:id="@+id/et_task_title_sheet"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_task_title_input"
        android:gravity="center_vertical"
        android:hint="@string/task_title_hint"
        android:inputType="textCapSentences"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#1F2937"
        android:textColorHint="#9CA3AF"
        android:textSize="15sp" />

    <!-- Date and Time Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_due_date_sheet"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/due_date"
            android:textAllCaps="false"
            android:textColor="#6B7280"
            android:textSize="14sp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_calendar"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="20dp"
            app:iconTint="#6B7280"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp" />

        <Space
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_due_time_sheet"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/due_time"
            android:textAllCaps="false"
            android:textColor="#6B7280"
            android:textSize="14sp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_clock"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="20dp"
            app:iconTint="#6B7280"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <!-- Priority Dropdown Box -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="@color/outline"
        app:hintEnabled="true"
        android:hint="@string/priority">

        <AutoCompleteTextView
            android:id="@+id/dropdown_priority_sheet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:inputType="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/priority_medium"
            android:textColor="#1F2937"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="28dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_task_sheet"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="#4B5563"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#F3F4F6"
            app:cornerRadius="12dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_task_sheet"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="14dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:text="@string/add"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="12dp"
            app:elevation="0dp" />
    </LinearLayout>

</LinearLayout>